package main

import "fmt"

func Depositar(saldo float64, saque float64) float64 {
	saldo += saque
	fmt.Println("Depósito de", saque, "realizado.")
	return saldo
}

func Sacar(saldo float64, saque float64) float64 {
	if saque > saldo {
		fmt.Println("Saldo insuficiente para saque", saque)
		return saldo
	}

	saldo -= saque
	fmt.Println("Saque de", saque, "realizado.")
	return saldo
}

func main() {
	var saldoDaConta float64 = 500.00

	fmt.Println("Saldo inicial da conta =", saldoDaConta)

	saldoDaConta = Depositar(saldoDaConta, 100.00)
	fmt.Println("Saldo da conta após depósito =", saldoDaConta)

	saldoDaConta = Sacar(saldoDaConta, 30.00)
	fmt.Println("Saldo da conta após saque =", saldoDaConta)

	saldoDaConta = Sacar(saldoDaConta, 800.00)
	fmt.Println("Saldo da conta após saque insuficiente =", saldoDaConta)
}
